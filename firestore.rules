rules_version = '2';

// Manchester Piti — Firestore security rules.
//
// Reconstructed from the app's Firestore usage (AuthContext, SeasonContext,
// Admin, Stats, MatchCenter, Expedientes, Landing, pizarra/*) and covering all
// five collections the app touches: players, matches, seasons, users, lineups.
//
// DEPLOYED 2026-06-16 (firebase deploy --only firestore) to futbolmanagement-dc6cb.
// The previous live ruleset was the default test-mode allow-all (expiring
// 2026-07-03), so nothing custom was lost. A deploy REPLACES the entire
// ruleset, so keep this file in sync and re-verify against the app's queries
// before any future deploy.
//
// AUDITED 2026-06-23 (Phase 11). Every write path was re-checked against the
// live code (Admin CRUD via useAdminMutations, AuthContext register/role,
// pizarra naturalPosition update on players, lineups CRUD + markOfficial). All
// role-based writes are correctly gated; no gap found, no rule change needed.
// The behaviour is locked in by emulator rules tests (see firestore-rules.test.ts
// + the `test:rules` script). Deploy target: Firebase Hosting (SPA rewrite in
// firebase.json) + Firestore rules/indexes — `firebase deploy --only firestore`
// for this file, `--only hosting` for the SPA. See firebase.json.
//
// INDEX NOTE (firestore.indexes.json): after Phase 1's de-dup, every `matches`
// query is `orderBy("date","desc")` ONLY (single-field → auto-indexed), so the
// old composite `matches(seasonId, date)` became dead config and was REMOVED in
// Phase 11. The `lineups(seasonId, isOfficial)` composite STAYS — markOfficial
// queries `where(seasonId==) && where(isOfficial==true)` (two equality filters
// → needs a composite). No other multi-filter/orderBy query exists.

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }
    function roleOf(uid) {
      return get(/databases/$(database)/documents/users/$(uid)).data.role;
    }
    function isAdmin() {
      return isSignedIn()
        && roleOf(request.auth.uid) in ['admin', 'superadmin'];
    }

    // Public read: the pre-login Landing reads players & matches (getDocs),
    // and SeasonContext subscribes to seasons before auth. Do NOT gate these
    // reads behind request.auth — it breaks the logged-out Landing page.

    match /players/{playerId} {
      allow read: if true;
      // Admin create/edit/delete (Admin.tsx) + Pizarra naturalPosition update.
      allow create, update, delete: if isAdmin();
    }

    match /matches/{matchId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /seasons/{seasonId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /users/{userId} {
      // Signed-in users read the collection: registration checks nickname
      // uniqueness / first-user, and Admin lists users.
      allow read: if isSignedIn();

      // Self-create profile. Restricted to role 'user' so a user cannot
      // self-assign elevated roles — EXCEPT the hardcoded superadmin email,
      // which AuthContext self-heals to 'superadmin'.
      // NOTE: the client also makes the *first ever* user an 'admin'. Rules
      // cannot detect "first user", so that bootstrap must be done once in the
      // console (set role: 'admin'/'superadmin' manually).
      allow create: if isSignedIn() && request.auth.uid == userId
        && (request.resource.data.role == 'user'
            || request.auth.token.email == 'adriantomascv@gmail.com');

      // Admins update anyone (role management). A user may update their own
      // doc only WITHOUT changing their role — except the superadmin email,
      // which may self-heal to 'superadmin'.
      allow update: if isAdmin()
        || (request.auth.uid == userId
            && request.resource.data.role == resource.data.role)
        || (request.auth.uid == userId
            && request.auth.token.email == 'adriantomascv@gmail.com');

      // No client deletes of user docs.
      allow delete: if false;
    }

    // Tactical lineups saved from La Pizarra (persistence sub-project).
    // Any signed-in user owns their own boards (create/edit/delete); only an
    // admin may publish a board as official (set/keep isOfficial true) or
    // touch someone else's board. ownerUid is the writer's uid.
    match /lineups/{lineupId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
        && request.resource.data.ownerUid == request.auth.uid
        && (request.resource.data.isOfficial == false || isAdmin());
      allow update: if isSignedIn() && (
           (resource.data.ownerUid == request.auth.uid
             && (request.resource.data.isOfficial == resource.data.isOfficial || isAdmin()))
           || isAdmin());
      allow delete: if isSignedIn()
        && (resource.data.ownerUid == request.auth.uid || isAdmin());
    }
  }
}
