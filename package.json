{
  "name": "manchester-piti",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "test": "vitest run",
    "preview": "vite preview",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:ci": "firebase emulators:exec --only auth,firestore --project futbolmanagement-dc6cb \"playwright test\"",
    "test:rules": "firebase emulators:exec --only firestore --project futbolmanagement-dc6cb \"pnpm exec vitest run --config vitest.rules.config.ts\"",
    "emulators": "firebase emulators:start --only auth,firestore --project futbolmanagement-dc6cb"
  },
