# Firebase Web SDK config (client-side). Copy this file to `.env` and fill in
# the values from your Firebase project → Project settings → General →
# "Your apps" → SDK setup and configuration. These are client keys (they ship
# in the browser bundle); real access control is enforced by Firestore Security
# Rules + Auth, but keep your own `.env` out of version control anyway.
VITE_FIREBASE_API_KEY=your-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=000000000000
VITE_FIREBASE_APP_ID=1:000000000000:web:0000000000000000000000
VITE_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX
